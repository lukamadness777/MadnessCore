{
	"schemaVersion": 1,
	"id": "madnesscore",
	"version": "${version}",
	"name": "Madness Core",
	"description": "A core API for LukaMadness mods, providing extensible systems for bloodlines, species, character customization, abilities, player offset adjustments, attributes, networking, and shared utilities.",
	"authors": [
		"LukaMadness"
	],
	"contact": {
		"sources": "https://github.com/lukamadness777/MadnessCore",
		"homepage": "https://yourwebsite.com",
		"issues": "https://github.com/lukamadness777/MadnessCore/issues"
	},
	"license": "GPL-3.0-or-later",
	"icon": "assets/madnesscore/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"dev.lukamadness.madnesscore.MadnessCore"
		],
		"client": [
          "dev.lukamadness.madnesscore.client.MadnessCoreClient"
		],
		"modmenu": [
			"dev.lukamadness.madnesscore.client.compat.ModMenuCompat"
		],
		"jei_mod_plugin": [
			"dev.lukamadness.madnesscore.client.compat.jei.MadnessCoreJeiPlugin"
		]
	},
	"mixins": [
		"madnesscore.mixins.json",
		{
			"config": "madnesscore.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~1.21.1",
		"java": ">=21",
		"fabric-api": "*"
	},
	"custom": {
		"modmenu": {
			"links": {
				"modmenu.discord": "https://discord.gg/rqFTEefmAT"
			}
		}
	}
}